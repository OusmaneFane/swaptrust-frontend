# Client (navigateur)
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001

# URL publique de l’app Next (obligatoire en prod Docker : même valeur que AUTH_URL)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret_min_32_chars
AUTH_SECRET=your_nextauth_secret_min_32_chars
# NextAuth v5 — même secret que AUTH_SECRET ; URL canonique https://ton-domaine.com (sans slash final)
AUTH_URL=http://localhost:3000

# Serveur Next (login next-auth, RSC) — obligatoire si NEXT_PUBLIC n’est pas injecté côté serveur
API_URL=http://localhost:3001/api/v1

