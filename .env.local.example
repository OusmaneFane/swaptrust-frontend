# Client (navigateur) — injectés au build Docker / CI
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001

# Runtime conteneur (fichier .env sur le serveur à côté de docker-compose, pas dans l’image)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret_min_32_chars
AUTH_SECRET=your_nextauth_secret_min_32_chars

# Serveur Next (rewrites, RSC) — secret GitHub + build Docker
API_URL=http://localhost:3001/api/v1

